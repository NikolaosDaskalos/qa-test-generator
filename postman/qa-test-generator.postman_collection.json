                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "sessions",
                "{{repositorySessionId}}",
                "questions"
              ]
            },
            "description": "Starts a Test-Generation Task through the unified session stream. When review accepts the generated patch, the stream ends with `review_result` and the persisted run waits for the owner decision at `awaiting_approval`; the request stores `codingRunId` for the decision and `/runs/*` requests."
          },
          "response": []
        },
