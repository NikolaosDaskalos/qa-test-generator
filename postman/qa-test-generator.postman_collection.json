                  "pm.test('Coding run state is returned', function () {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.id).to.eql(pm.variables.get('codingRunId'));",
                  "    pm.expect(response.status).to.be.oneOf(['queued', 'planning', 'retrieving', 'generating', 'awaiting_review', 'reviewing', 'awaiting_approval', 'changes_requested', 'approved', 'succeeded', 'rejected', 'failed']);",
                  "    pm.expect(response.review_findings).to.be.an('array');",
                  "    pm.expect(response.disclaimer).to.be.a('string').and.not.empty;",
                  "});"
                ]
              }
