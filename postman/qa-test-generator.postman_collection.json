        {
          "name": "Ask Repository Question",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response is a server-sent event stream', function () {",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.include('text/event-stream');",
                  "});",
                  "",
                  "function readSseEvents() {",
                  "    return pm.response.text()",
                  "        .split(/\\r?\\n/)",
                  "        .filter(line => line.startsWith('data: '))",
                  "        .map(line => JSON.parse(line.slice(6)));",
                  "}",
                  "",
                  "pm.test('Stream ends with a single terminal result frame', function () {",
                  "    const events = readSseEvents();",
                  "    pm.expect(events).not.to.be.empty;",
                  "    pm.expect(events.some(event => event.type === 'token')).to.be.true;",
                  "    pm.expect(events.some(event => event.type === 'done')).to.be.false;",
                  "    pm.expect(events.filter(event => event.type === 'result')).to.have.lengthOf(1);",
                  "    const result = events[events.length - 1];",
                  "    pm.expect(result.type).to.eql('result');",
                  "    pm.expect(result.repository_session_id).to.eql(pm.variables.get('repositorySessionId'));",
                  "    pm.expect(result.assistant_message_id).to.be.a('string').and.not.empty;",
                  "    pm.expect(result.answer).to.be.a('string').and.not.empty;",
                  "    pm.expect(result.citations).to.be.an('array');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "text/event-stream"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"question\": \"{{repositoryQuestion}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/sessions/{{repositorySessionId}}/questions",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "sessions",
                "{{repositorySessionId}}",
                "questions"
              ]
            },
            "description": "Streams a repository-grounded answer as server-sent events. The stream emits progress, token, and terminal `result` events; citations are included on the terminal result."
          },
          "response": []
        },
        {
          "name": "Start Test Generation (Await Human Decision)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.environment.set('codingRunAwaitingDecision', 'false');",
                  "pm.collectionVariables.set('codingRunAwaitingDecision', 'false');",
                  "",
                  "pm.test('Response is a server-sent event stream', function () {",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.include('text/event-stream');",
                  "});",
                  "",
                  "function readSseEvents() {",
                  "    return pm.response.text()",
                  "        .split(/\\r?\\n/)",
                  "        .filter(line => line.startsWith('data: '))",
                  "        .map(line => JSON.parse(line.slice(6)));",
                  "}",
                  "",
                  "pm.test('Test-generation stream exposes and stores the coding run id', function () {",
                  "    const events = readSseEvents();",
                  "    pm.expect(events).not.to.be.empty;",
                  "    pm.expect(events.some(event => event.type === 'run_started')).to.be.true;",
                  "    pm.expect(events.some(event => event.type === 'done')).to.be.false;",
                  "    const runEvent = events.find(event => event.coding_run_id);",
                  "    pm.expect(runEvent, JSON.stringify(events)).to.exist;",
                  "    pm.expect(runEvent.coding_run_id).to.be.a('string').and.not.empty;",
                  "    pm.environment.set('codingRunId', runEvent.coding_run_id);",
                  "    pm.collectionVariables.set('codingRunId', runEvent.coding_run_id);",
                  "});",
                  "",
                  "pm.test('review_result carries the human-decision handoff when accepted', function () {",
                  "    const events = readSseEvents();",
                  "    const terminal = events[events.length - 1];",
                  "    pm.expect(terminal.type).to.be.oneOf(['review_result', 'run_failure']);",
                  "    if (terminal.type === 'review_result') {",
                  "        pm.expect(terminal.accepted).to.be.a('boolean');",
                  "        pm.expect(terminal.coding_run_id).to.eql(pm.variables.get('codingRunId'));",
                  "        pm.expect(terminal.findings).to.be.an('array');",
                  "        pm.expect(terminal.diff).to.be.a('string');",
                  "        pm.expect(terminal.disclaimer).to.be.a('string').and.not.empty;",
                  "        if (terminal.accepted) {",
                  "            pm.environment.set('codingRunAwaitingDecision', 'true');",
                  "            pm.collectionVariables.set('codingRunAwaitingDecision', 'true');",
                  "        } else {",
                  "            pm.environment.set('codingRunAwaitingDecision', 'false');",
                  "            pm.collectionVariables.set('codingRunAwaitingDecision', 'false');",
                  "        }",
                  "    }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "text/event-stream"
