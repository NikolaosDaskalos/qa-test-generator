            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/sessions/{{repositorySessionId}}/runs/{{codingRunId}}/patch",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "sessions",
                "{{repositorySessionId}}",
                "runs",
                "{{codingRunId}}",
                "patch"
              ]
            },
            "description": "Reads the persisted canonical diff, generated file proposals, and external references for an owned Coding Run."
          },
          "response": []
        },
        {
          "name": "Send Coding Run Decision",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response is a server-sent event stream', function () {",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.include('text/event-stream');",
                  "});",
                  "",
                  "function readSseEvents() {",
                  "    return pm.response.text()",
                  "        .split(/\\r?\\n/)",
                  "        .filter(line => line.startsWith('data: '))",
                  "        .map(line => JSON.parse(line.slice(6)));",
                  "}",
                  "",
                  "pm.test('Decision resumes the paused run and emits an approval/rejection terminal event', function () {",
                  "    const events = readSseEvents();",
                  "    pm.expect(events).not.to.be.empty;",
                  "    const terminal = events[events.length - 1];",
                  "    const expectedTerminal = String(pm.variables.get('approveCodingRun')) === 'true' ? 'run_approved' : 'run_rejected';",
                  "    pm.expect(terminal.type).to.eql(expectedTerminal);",
                  "    pm.expect(terminal.coding_run_id).to.eql(pm.variables.get('codingRunId'));",
                  "    pm.expect(terminal.diff).to.be.a('string');",
                  "    pm.expect(terminal.disclaimer).to.be.a('string').and.not.empty;",
                  "    if (terminal.type === 'run_approved') {",
                  "        pm.expect(terminal.branch).to.be.a('string').and.not.empty;",
                  "    } else {",
                  "        pm.expect(terminal.findings).to.be.an('array');",
                  "    }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "text/event-stream"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"decision\": {\n    \"coding_run_id\": \"{{codingRunId}}\",\n    \"approved\": {{approveCodingRun}},\n    \"feedback\": \"{{decisionFeedback}}\"\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/sessions/{{repositorySessionId}}/questions",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "sessions",
                "{{repositorySessionId}}",
                "questions"
              ]
            },
            "description": "Resumes a paused `awaiting_approval` Coding Run through the same `POST /sessions/{repositorySessionId}/questions` endpoint. Set `approveCodingRun` to `true` to commit and push the generated branch, or `false` to reject and discard the patch."
          },
          "response": []
        },
        {
          "name": "Get Session History",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Session history is returned in message order', function () {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.data).to.be.an('array');",
                  "    response.data.forEach(function (message, index) {",
                  "        pm.expect(message.id).to.be.a('string').and.not.empty;",
                  "        pm.expect(message.session_id).to.eql(pm.variables.get('repositorySessionId'));",
                  "        pm.expect(message.role).to.be.oneOf(['user', 'assistant']);",
                  "        pm.expect(message.content).to.be.a('string');",
                  "        pm.expect(message.citations).to.be.an('array');",
                  "        pm.expect(message.position).to.be.a('number');",
                  "        pm.expect(message.created_at).to.be.a('string').and.not.empty;",
                  "        if (index > 0) {",
                  "            pm.expect(message.position).to.be.above(response.data[index - 1].position);",
                  "        }",
                  "    });",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/sessions/{{repositorySessionId}}/history",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "sessions",
                "{{repositorySessionId}}",
                "history"
              ]
            },
            "description": "Returns the recent ordered message history for a session owned by the authenticated user."
          },
          "response": []
        }
      ]
    }
